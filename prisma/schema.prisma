// Travel Planner — full ER per plan.md §3.
// SQLite for Phase 0b (local self-use). Switching to Postgres later only
// requires changing the datasource provider; relations and field types are
// chosen to be portable.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// User / sharing — Phase 8 link-based collaboration
//
// Users are created automatically on first visit (auto-guest mode) keyed by
// a cookie. No registration UI; the cookie IS the identity. Users own trips
// and can be members of trips they were invited to via a share link.
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id          String   @id @default(cuid())
  displayName String // Auto-generated like "訪客 #A3F7" — editable later.
  isGuest     Boolean  @default(true) // false reserved for future registered accounts
  createdAt   DateTime @default(now())
  lastSeenAt  DateTime @default(now())

  ownedTrips    Trip[]        @relation("TripOwner")
  memberships   TripMember[]
  createdShares TripShare[]
}

// A share link issued by a trip owner. Anyone with the URL `?t=<token>` can
// join the trip and become a TripMember with the share's `role`. The token
// stored here is its SHA-256 hash; the raw token only exists in the URL the
// owner copies / sends.
model TripShare {
  id          String    @id @default(cuid())
  tripId      String
  trip        Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  tokenHash   String    @unique
  role        String // "editor" | "viewer"
  label       String? // friendly label e.g. "給家人", "團員 A"
  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())
  expiresAt   DateTime?
  revokedAt   DateTime?

  members TripMember[]

  @@index([tripId])
}

// Persistent membership: once a User joins a Trip via a share link, this row
// records their access. Revoking the link sets revokedAt on the link AND
// optionally removes members who joined through it (caller's choice).
model TripMember {
  tripId           String
  trip             Trip       @relation(fields: [tripId], references: [id], onDelete: Cascade)
  userId           String
  user             User       @relation(fields: [userId], references: [id])
  role             String // "owner" | "editor" | "viewer"
  joinedViaShareId String?
  joinedVia        TripShare? @relation(fields: [joinedViaShareId], references: [id])
  joinedAt         DateTime   @default(now())
  lastSeenAt       DateTime   @default(now())
  removedAt        DateTime?

  @@id([tripId, userId])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Trip / Plan / Day / ScheduleItem core
// ─────────────────────────────────────────────────────────────────────────────

model Trip {
  id            String   @id @default(cuid())
  // Owner — User.id of whoever created the trip. Phase 7 single-user mode
  // pre-existing rows have ownerId = "default-user" (a real User row is
  // seeded for that id). New trips written through createTrip set ownerId
  // to the current cookie-resolved user.
  userId        String   @default("default-user")
  owner         User     @relation("TripOwner", fields: [userId], references: [id])
  title         String
  startDate     DateTime
  endDate       DateTime
  baseCurrency  String   @default("TWD")
  defaultPlanId String?

  // Display-only fields (used by dashboard cards). Editor pages pull a richer
  // computed view via service layer.
  destination   String?
  subtitle      String?
  coverColor    String   @default("from-gray-400 to-gray-600")
  coverIconKey  String   @default("landmark")
  status        String   @default("active") // active | past | upcoming

  plans    Plan[]
  expenses Expense[]
  shares   TripShare[]
  members  TripMember[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Plan {
  id               String  @id @default(cuid())
  tripId           String
  trip             Trip    @relation(fields: [tripId], references: [id], onDelete: Cascade)
  name             String
  displayOrder     Int     @default(0)
  forkedFromPlanId String?
  pace             String  @default("standard") // 輕鬆 | 標準 | 緊湊
  description      String?

  days          Day[]
  expenses      Expense[]
  aiSuggestions AISuggestion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tripId])
}

model Day {
  id       String   @id @default(cuid())
  planId   String
  plan     Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  date     DateTime
  dayIndex Int
  note     String?
  // Phase 12f — monotonic version incremented in the same transaction as
  // any commitDayEdits batch, so the optimistic week-view client can detect
  // stale baselines (concurrent edits via TripShare) and surface a conflict
  // toast instead of silently overwriting.
  version  Int      @default(0)

  scheduleItems ScheduleItem[]

  @@index([planId])
}

model ScheduleItem {
  id           String  @id @default(cuid())
  dayId        String
  day          Day     @relation(fields: [dayId], references: [id], onDelete: Cascade)
  kind         String // ATTRACTION | MEAL | LODGING | TRANSPORT_STOP | FREE | FLIGHT | CAR_RENTAL | TRAIN
  placeId      String?
  place        Place?  @relation(fields: [placeId], references: [googlePlaceId])

  startTime            String // HH:mm (local time, no timezone)
  endTime              String
  durationMin          Int
  suggestedDurationMin Int?
  isAllDay             Boolean @default(false)
  isTimeLocked         Boolean @default(false)
  orderIndex           Int     @default(0)
  note                 String?
  // Phase 10c — kind-specific structured fields validated by Zod per kind
  // (FlightMetadata / MealMetadata / LodgingMetadata / CarRentalMetadata / ...).
  // Stored as JSON so adding new kinds doesn't require schema migrations.
  metadataJson String?
  // Phase 10d — for FLIGHT-derived helper items (check-in / immigration),
  // points back to the FLIGHT scheduleItem so we can rebuild buffers when
  // the flight times change.
  parentFlightScheduleItemId String?

  outgoingTransport Transport? @relation("FromItem")
  incomingTransport Transport? @relation("ToItem")

  tickets  Ticket[]
  expenses Expense[]
  photos   Photo[]

  @@index([dayId])
  @@index([placeId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Place (shared cache, keyed by google place_id)
// ─────────────────────────────────────────────────────────────────────────────

model Place {
  googlePlaceId      String  @id
  name               String
  // Phase 12a — user-editable display name. When non-null this overrides the
  // canonical Google name in UI. `name` is kept as a denormalized cache equal
  // to `userEditedName ?? originalName` so existing readers (7+ components)
  // don't need to know about the override; service writes keep it in sync.
  originalName       String
  userEditedName     String?
  category           String
  address            String?
  lat                Float?
  lng                Float?
  primaryType        String?
  types              String? // JSON-encoded string array
  rating             Float?
  ratingCount        Int?
  defaultStayMinutes Int     @default(60)
  defaultStaySource  String  @default("HEURISTIC") // HEURISTIC | AI | USER_OVERRIDE
  iconKey            String  @default("landmark")

  // Phase 0a stylized-map layout fields. Phase 1a Google Maps will rely on lat/lng.
  mapX          Float?
  mapY          Float?
  reviewSnippet String?

  detailsExpireAt DateTime?
  fetchedAt       DateTime  @default(now())

  scheduleItems      ScheduleItem[]
  parkingSuggestions Transport[]    @relation("ParkingSuggestion")
  photos             PlacePhoto[]
}

model PlacePhoto {
  id             String  @id @default(cuid())
  googlePlaceId  String
  place          Place   @relation(fields: [googlePlaceId], references: [googlePlaceId], onDelete: Cascade)
  photoReference String
  localCachePath String?
  widthPx        Int?

  @@index([googlePlaceId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Transport (between two ScheduleItems)
// ─────────────────────────────────────────────────────────────────────────────

model Transport {
  id                  String       @id @default(cuid())
  fromScheduleItemId  String       @unique
  toScheduleItemId    String       @unique
  fromItem            ScheduleItem @relation("FromItem", fields: [fromScheduleItemId], references: [id], onDelete: Cascade)
  toItem              ScheduleItem @relation("ToItem", fields: [toScheduleItemId], references: [id], onDelete: Cascade)

  mode           String // DRIVING | TRANSIT | WALKING | BICYCLING | CUSTOM | FLIGHT
  distanceMeters Int?
  durationSec    Int?
  polyline       String? // JSON-encoded LatLng array
  parkingPlaceId String?
  parkingPlace   Place?  @relation("ParkingSuggestion", fields: [parkingPlaceId], references: [googlePlaceId])
  estimatedCost  Float?

  // ─ Phase 9 — Google Routes API real-route caching ─
  // Encoded polyline (Google's algorithm) for the chosen mode. Decoded on
  // the client to draw the line on whichever map provider is in use.
  encodedPolyline    String?
  // Full Routes API response for the chosen mode (slim — fields trimmed via
  // X-Goog-FieldMask). Used by TransportEditDialog detail panels.
  directionsCacheJson String?
  directionsFetchedAt DateTime?
  // Lightweight side-by-side compare: { DRIVE: {km, sec, cost}, TRANSIT: ..., ... }
  modesSummaryJson    String?
  // ISO-8601 (e.g. "2026-04-30T09:00:00Z") used as the API's departureTime
  // — derived from from_item.endTime + day.date. Cached so we know whether
  // a refresh is needed when the user edits times.
  departureAtIso      String?
  // Driving traffic level at that departureTime (light | moderate | heavy)
  trafficLevel        String?
  // Transit fare in the route's currency, copied to estimatedCost on save
  // for budget rollups but kept here untouched for display ("¥210 JR").
  fareCurrency        String?
  fareAmount          Float?

  // Manual editing — when true, recalcDayTransports skips this segment so
  // user-overridden mode/distance/duration/cost survives place reordering.
  manuallyEdited     Boolean @default(false)
  // Phase 12a — "free" state: no concrete transport mode/duration assigned
  // yet. Cascade engine treats this segment as 0-second; week view renders
  // it as a dashed 0-height line so the two adjacent places sit flush.
  isFree             Boolean @default(false)
  notes              String?
  // Transit-specific (free-form)
  transitLine        String? // e.g. "JR山手線 → 銀座線"
  transitDetailsJson String? // JSON: { stops: [...], transfers: [...], cost: ... }
  // Phase 12b — rich step-by-step transit timeline (walk + ride segments
  // with line color, station IDs, platform, headsign). Populated by the
  // LLM paste-parser when the user pastes a Google Maps "詳細路線" view.
  // See lib/services/transit-steps-types.ts for the JSON shape.
  transitStepsJson   String?
  // Optional override labels (overrides "from-place → to-place" auto display)
  originLabel        String?
  destinationLabel   String?
  // AI suggestion provenance — set by suggestTransport AI flow
  aiGeneratedAt      DateTime?
  // Phase 10i — kind-specific structured fields (currently only FLIGHT mode
  // uses this: airline / flight number / dep+arr time / seat / ...).
  // Same JSON shape as ScheduleItem.metadataJson per
  // lib/schedule-item-metadata.ts.
  metadataJson       String?

  // Phase 11 — Google-Maps-style point-to-point picker.
  // routeOptionsJson holds the full RouteOption[] snapshot (incl. unselected
  // alternatives) so the picker can re-render without re-querying Routes API.
  // selectedOptionId references one entry inside that array — the option
  // the user currently has applied.
  routeOptionsJson   String?
  selectedOptionId   String?
  // Frozen at apply-time so future changes to the global region rate table
  // don't retroactively alter cost displays for already-saved transports.
  taxiRateSnapshotJson String?

  // Phase 12c — DRIVING-only: LLM-grounded segment breakdown
  // (平面 / 收費 / 高速 with toll fees) + fuel estimate + highway rest
  // areas. Populated on user click; fuel estimate (tier 1) is recomputed
  // every render from polyline distance + Settings fuel defaults.
  // See lib/services/driving-segments-types.ts for shape.
  drivingSegmentsJson  String?

  expenses Expense[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────────────────────
// Ticket / Expense (1:1 auto-synced via service layer)
// ─────────────────────────────────────────────────────────────────────────────

model Ticket {
  id                 String       @id @default(cuid())
  scheduleItemId     String
  scheduleItem       ScheduleItem @relation(fields: [scheduleItemId], references: [id], onDelete: Cascade)
  category           String // ENTRY | TRANSPORT | EVENT
  title              String
  price              Float
  currency           String       @default("TWD")
  quantity           Int          @default(1)
  bookingRef         String?
  fileAttachmentPath String?
  expenseId          String       @unique
  expense            Expense      @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([scheduleItemId])
}

model Expense {
  id             String        @id @default(cuid())
  tripId         String
  trip           Trip          @relation(fields: [tripId], references: [id], onDelete: Cascade)
  planId         String
  plan           Plan          @relation(fields: [planId], references: [id], onDelete: Cascade)
  scheduleItemId String?
  scheduleItem   ScheduleItem? @relation(fields: [scheduleItemId], references: [id], onDelete: SetNull)
  transportId    String?
  transport      Transport?    @relation(fields: [transportId], references: [id], onDelete: SetNull)

  category     String // FOOD | LODGING | TRANSPORT | TICKET | SHOPPING | MISC | FLIGHT
  amount       Float
  currency     String  @default("TWD")
  fxRateToBase Float?
  note         String?
  occurredAt   DateTime?

  // Phase 10a — distinguishes auto-derived expenses (transport fare, fuel,
  // ticket-from-Ticket, scheduleItem-metadata-cost) from user-entered ones.
  // recalcPlanExpenses() wipes + rebuilds isAuto rows; manual rows survive.
  isAuto      Boolean @default(false)
  // Why was this auto-row created. Lets the UI explain it without a JOIN.
  // "TRANSPORT_FARE" | "TRANSPORT_FUEL" | "TICKET_LINK" | "MEAL_BUDGET" |
  // "ATTRACTION_TICKET" | "LODGING_TOTAL" | "CAR_RENTAL_TOTAL" | "FLIGHT_TICKET"
  autoSource  String?

  ticket Ticket? // 1:1 reverse via Ticket.expenseId

  @@index([tripId])
  @@index([planId])
  @@index([planId, isAuto])
}

// ─────────────────────────────────────────────────────────────────────────────
// Phase 10b — Photo (per scheduleItem or per place)
// Stored as base64 in the dev SQLite for simplicity. Cloudflare deploy
// switches to R2 by replacing data with a URL field; the rest of the app
// reads through `data ?? url` indirection.
// ─────────────────────────────────────────────────────────────────────────────

model Photo {
  id String @id @default(cuid())

  scheduleItemId String?
  scheduleItem   ScheduleItem? @relation(fields: [scheduleItemId], references: [id], onDelete: Cascade)

  // Optional caption shown beneath the photo
  caption String?
  // MIME type (e.g. "image/jpeg" / "image/png")
  mimeType String

  // ONE of the two below is set:
  //   data  → base64-encoded bytes (dev mode)
  //   url   → R2 / Cloudinary / etc URL (prod mode)
  data String? // base64
  url  String?

  // Soft size hint so we can show "1.2 MB" without re-decoding
  byteSize Int?
  // Display order within the parent
  orderIndex Int @default(0)

  createdAt DateTime @default(now())

  @@index([scheduleItemId, orderIndex])
}

// ─────────────────────────────────────────────────────────────────────────────
// AI suggestions (cached per Plan)
// ─────────────────────────────────────────────────────────────────────────────

model AISuggestion {
  id          String   @id @default(cuid())
  planId      String
  plan        Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  kind        String // PRE_TRIP_NOTES | PACKING_CHECKLIST
  input       String // JSON snapshot of plan context fed to LLM
  output      String // JSON structured output
  providerId  String
  model       String
  generatedAt DateTime @default(now())

  @@index([planId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Settings — one row per user. Phase 0–6 single-user mode means there is
// only one row with id="default-user"; the historical "singleton" row
// is migrated to "default-user" by the multi-user migration. SaaS mode
// just spawns one row per signup.
// ─────────────────────────────────────────────────────────────────────────────

model Settings {
  id String @id @default("default-user")

  // LLM — JSON array of { id, label, kind, model, baseUrl?, apiKeyEnc, lastTestedAt? }
  llmProviders             String  @default("[]")
  defaultProviderId        String?
  defaultModel             String?

  // Map provider — "google" | "mapbox" | "osm"
  mapProvider              String  @default("osm")

  // Google
  googleMapsApiKeyEnc      String?
  googleMapId              String? // Cloud-Console-generated Map ID (enables AdvancedMarker)

  // Mapbox
  mapboxApiKeyEnc          String?

  // AviationStack — free tier (100 req/month) for real flight schedule lookups
  // (airline / airport / dep+arr time given an IATA flight number).
  aviationStackKeyEnc      String?

  // AeroDataBox (RapidAPI) — second free tier (~500 req/month) used as
  // fallback when AviationStack misses or quota is exhausted. Same flight-by-
  // number lookup, slightly richer fields (terminal/gate on both ends).
  aeroDataBoxKeyEnc        String?

  // Place defaults — JSON map: { tourist_attraction: 90, restaurant: 60, ... }
  defaultStayMinutesByType String  @default("{}")

  // Driving fuel cost defaults
  defaultFuelPricePerLiter    Float @default(35.0)
  defaultFuelEfficiencyKmPerL Float @default(15.0)

  // Currency
  baseCurrency  String @default("TWD")
  localCurrency String @default("JPY")
  // JSON snapshot of last-fetched rates: { JPY: 4.76, USD: 0.031, ... }
  fxRates       String? @default("{\"TWD\":1,\"JPY\":4.76,\"USD\":0.031}")
  fxFetchedAt   DateTime?

  // Optional soft cap on monthly LLM/API spend, in USD
  monthlyBudgetUsd Float?

  // Phase 11 — point-to-point picker
  // taxiRegionRatesJson: { TW: { baseFare, perKm, perMin, currency }, JP: {...}, ... }
  // recommendWeightsJson: { time, cost, comfort, co2 } each 0..1, sum=1
  taxiRegionRatesJson  String?
  recommendWeightsJson String?

  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────────────────────
// API usage log (Phase 4 dashboard reads from here)
// ─────────────────────────────────────────────────────────────────────────────

model ApiUsageLog {
  id               String   @id @default(cuid())
  userId           String   @default("default-user")
  service          String // GOOGLE_PLACES_AUTOCOMPLETE | ... | LLM_CHAT | LLM_GENERATE_OBJECT
  providerId       String?
  model            String?
  promptTokens     Int?
  completionTokens Int?
  estimatedCostUsd Float?
  occurredAt       DateTime @default(now())
  metadata         String? // JSON-encoded extras (placeId, planId)

  @@index([service, occurredAt])
  @@index([userId, occurredAt])
}
