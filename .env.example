# ─── Database ───────────────────────────────────────────────────────────────
# Postgres (Neon / Supabase / RDS / 自架). 格式：
#   postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
# 本地 dev 時建議建一個 Neon 免費 dev branch；正式部署 Vercel 會用同一條
# connection string（在 Vercel 環境變數設）。
DATABASE_URL=""

# ─── App encryption ─────────────────────────────────────────────────────────
# Master key used by lib/crypto.ts (AES-256-GCM) to encrypt LLM / Google API
# keys before they hit the DB. Generate one with:
#   openssl rand -base64 32
APP_ENC_KEY=""

# ─── Google Maps Platform (Phase 1a) ────────────────────────────────────────
# JS API key — restrict by HTTP referrer (used in browser)
NEXT_PUBLIC_GOOGLE_MAPS_JS_KEY=""
# Server key — restrict by IP (used by /api/places, /api/directions proxies)
GOOGLE_MAPS_SERVER_KEY=""
